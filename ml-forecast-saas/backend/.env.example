# ================================================================
# .env.example — Environment variables for ML Forecast SaaS
# ================================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For Hugging Face Spaces: Set these in Settings > Secrets & Variables
# ================================================================

# ---- Security (REQUIRED in production) ----
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-very-secure-random-hex-string-here

# ---- App Settings ----
ENVIRONMENT=production
DEBUG=false

# ---- Database ----
# For local dev, use SQLite:
DATABASE_URL=sqlite:///./data/forecast.db
# For production (Supabase), set these instead:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your-supabase-service-key

# ---- CORS Origins (comma-separated) ----
ALLOWED_ORIGINS=https://ibadatali-walmart-sales-forecasting-saas.hf.space,http://localhost:5173

# ---- Frontend URL (used for OAuth redirects) ----
FRONTEND_URL=https://ibadatali-walmart-sales-forecasting-saas.hf.space

# ---- OAuth (Social Login) — Leave blank to disable ----
# Google OAuth:
#   → Create at: https://console.cloud.google.com/apis/credentials
#   → Redirect URI: {FRONTEND_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth:
#   → Create at: https://github.com/settings/developers
#   → Callback URL: {FRONTEND_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft Azure OAuth:
#   → Create at: https://portal.azure.com → App registrations
#   → Redirect URI: {FRONTEND_URL}/api/auth/callback/microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ---- Port (Hugging Face uses 7860) ----
PORT=7860
